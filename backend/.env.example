PORT=5001
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# In-memory storage does NOT persist or share across serverless invocations, so
# rate limits are not enforced in production. Point this at a shared backend
# (e.g. redis://... or an Upstash URL) when deploying.
RATELIMIT_STORAGE_URI=memory://
# Set to false to disable rate limiting entirely (e.g. in tests).
RATELIMIT_ENABLED=true
MAX_REQUEST_BYTES=16777216
MAX_ZIP_BYTES=262144000
MAX_ZIP_UPLOAD_BYTES=262144000
# Per-channel pixel ceiling for composite preview rendering (bounds peak memory).
MAX_RENDER_PIXELS=40000000
BLOB_UPLOAD_TOKEN_RATE_LIMIT=30
# Optional: force Vercel Blob upload callbacks to a known deployment origin.
# BLOB_UPLOAD_CALLBACK_ORIGIN=https://your-production-domain.example

# Local development writes temporary blot files here. If omitted, the OS temp
# directory is used.
BLOT_TEMP_STORAGE=local
BLOT_TEMP_DIR=/tmp/western-blot-browser-only

# Vercel production should use Blob-backed temporary storage instead.
# BLOT_TEMP_STORAGE=vercel-blob
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Temporary blot files are PRIVATE by default. BLOB_ACCESS=public makes them
# world-readable by URL and is ignored unless BLOB_PUBLIC_ACCESS_ACK=true is
# also set as an explicit acknowledgment.
# BLOB_ACCESS=public
# BLOB_PUBLIC_ACCESS_ACK=true
