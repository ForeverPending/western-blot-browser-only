PORT=5001
BLOT_STORAGE_BACKEND=local
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
RATELIMIT_STORAGE_URI=memory://
MAX_REQUEST_BYTES=16777216

# Required for authentication in every storage mode.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_BUCKET=western-blots

# Optional. Reserved for controlled background jobs, Stripe webhooks, and
# administration. Normal user request handlers must never use this key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
